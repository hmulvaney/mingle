# Mingle uses Upstash Redis for storage (free tier).
# When these are unset, Mingle falls back to an in-memory store so you can
# run `npm run dev` and try the concept locally without any account.
#
# To get real, shared storage:
#   1. Deploy to Vercel and add the "Upstash" integration from the Marketplace,
#      which sets these automatically, OR
#   2. Create a free database at https://console.upstash.com and copy the
#      REST URL + token below into a .env.local file.

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
